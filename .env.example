# Local Hugging Face Jobs settings.
# Copy to `.env` and fill only the values you need.

# Hugging Face user access token.
# Required only for direct token login or artifact upload from the Job.
HF_TOKEN=

# Optional upload target for completed run directories.
# Example: HF_OUTPUT_REPO_ID=your-hf-username/derma-jepa-runs
HF_OUTPUT_REPO_ID=
HF_OUTPUT_REPO_TYPE=dataset
HF_OUTPUT_PATH=

# Default hosted fixture smoke settings.
HF_JOBS_FLAVOR=cpu-upgrade
HF_JOBS_TIMEOUT=2h
HF_JOBS_DETACH=0
HF_JOBS_NAMESPACE=

# DermaJEPA package/config refs used by scripts/hf_jobs_train.sh.
DERMA_JEPA_REF=main
DERMA_JEPA_RUN_ID=
DERMA_JEPA_CONFIG_PATH=configs/train/jepa_predictor.yaml
DERMA_JEPA_CONFIG_URL=
DERMA_JEPA_INSTALL_EXTRAS=
DERMA_JEPA_OUTPUT_ROOT=outputs/runs
DERMA_JEPA_ARTIFACT_ROOT=outputs/artifacts/demo

# Set to 1 to print the hf jobs command without launching compute.
HF_JOBS_DRY_RUN=0
